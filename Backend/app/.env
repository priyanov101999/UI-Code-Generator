########################################
# 🔥 MODEL CONFIGURATION
########################################

# Choose which CodeLlama model to load
# Recommended: 7B for Mac/CPU, 13B for GPU
CODELLAMA_MODEL="mistralai/Mistral-7B-Instruct-v0.3"


# Quantization options:
# none  → best quality, more VRAM
# 4bit  → uses BitsAndBytes to run on smaller GPUs / CPUs
CODELLAMA_QUANT=4bit


########################################
# 🔥 GENERATION PARAMETERS
########################################

# Maximum tokens the model generates
GEN_MAX_NEW_TOKENS=1000

# Controls creativity (lower = more deterministic)
GEN_TEMPERATURE=0.2

# Controls sample diversity (lower = more strict)
GEN_TOP_P=0.9

# Discourages repeated tokens
GEN_REP_PENALTY=1.05


########################################
# 🔥 RAG / VECTORSTORE SETTINGS
########################################

# How many similar code chunks to retrieve from DB
RAG_TOP_K=6

# Folder where Chroma stores embeddings
CHROMA_DIR=chroma_db


########################################
# 🔥 GENERAL
########################################

# Optional: restrict HF logging
HF_HUB_ENABLE_HF_TRANSFER=1
TOKENIZERS_PARALLELISM=false
